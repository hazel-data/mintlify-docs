{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Hazel Docs",
  "colors": {
    "primary": "#4A6E3F",
    "light": "#5C8A4E",
    "dark": "#382C29"
  },
  "logo": {
    "light": "/images/hazel-wordmark-dark.png",
    "dark": "/images/hazel-wordmark-light.svg",
    "href": "https://fromhazel.ai"
  },
  "favicon": "/images/hazel-icon.svg",
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#FFFCF7",
      "dark": "#1C1917"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Sign in",
        "href": "https://app.fromhazel.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get a demo",
      "href": "https://fromhazel.ai/demo"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/fromhazel",
      "x": "https://x.com/fromhazel"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Features", "href": "https://fromhazel.ai/#features" },
          { "label": "Integrations", "href": "/integrations/overview" },
          { "label": "Pricing", "href": "https://fromhazel.ai/pricing" }
        ]
      },
      {
        "header": "Resources",
        "items": [
          { "label": "Documentation", "href": "/getting-started/welcome" },
          { "label": "Prompt library", "href": "/recipes/overview" },
          { "label": "What's new", "href": "/resources/whats-new" }
        ]
      },
      {
        "header": "Company",
        "items": [
          { "label": "About", "href": "https://fromhazel.ai/about" },
          { "label": "Contact", "href": "/resources/contact-support" },
          { "label": "Privacy", "href": "https://fromhazel.ai/privacy" }
        ]
      }
    ]
  },
  "search": {
    "prompt": "Search Hazel docs..."
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
              "getting-started/welcome",
              "getting-started/quickstart",
              "getting-started/key-concepts"
            ]
          },
          {
            "group": "Features",
            "icon": "sparkles",
            "pages": [
              "features/chat",
              "features/quick-ask-vs-deep-thinking",
              "features/charts-and-tables",
              "features/citations",
              "features/memory",
              "features/scheduled-reports",
              "features/weekly-reviews",
              "features/alerts",
              "features/team-management"
            ]
          },
          {
            "group": "Resources",
            "icon": "life-buoy",
            "pages": [
              "resources/faq",
              "resources/whats-new",
              "resources/contact-support"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "icon": "plug",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "integrations/overview",
              "integrations/connecting-a-source",
              "integrations/all-integrations"
            ]
          },
          {
            "group": "Marketing",
            "pages": [
              "integrations/meta-ads",
              "integrations/google-ads",
              "integrations/google-analytics",
              "integrations/tiktok-ads",
              "integrations/klaviyo",
              "integrations/attentive",
              "integrations/fairing"
            ]
          },
          {
            "group": "Sales & commerce",
            "pages": [
              "integrations/shopify",
              "integrations/amazon"
            ]
          },
          {
            "group": "Finance",
            "pages": [
              "integrations/stripe"
            ]
          },
          {
            "group": "Support",
            "pages": [
              "integrations/gorgias",
              "integrations/zendesk"
            ]
          },
          {
            "group": "Reviews",
            "pages": [
              "integrations/okendo"
            ]
          }
        ]
      },
      {
        "tab": "Recipes & prompts",
        "icon": "lightbulb",
        "groups": [
          {
            "group": "Prompt library",
            "pages": [
              "recipes/overview",
              "recipes/marketing-analysis",
              "recipes/customer-insights",
              "recipes/product-performance",
              "recipes/ad-spend-optimization",
              "recipes/retention-and-ltv",
              "recipes/support-operations",
              "recipes/weekly-reporting"
            ]
          }
        ]
      }
    ]
  }
}
