{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Hazel Docs",
  "colors": {
    "primary": "#4A6E3F",
    "light": "#5C8A4E",
    "dark": "#382C29"
  },
  "logo": {
    "light": "/images/hazel-wordmark-dark.png",
    "dark": "/images/hazel-wordmark-light.svg",
    "href": "https://fromhazel.ai"
  },
  "favicon": "/images/hazel-icon.svg",
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#FFFCF7",
      "dark": "#1C1917"
    }
  },
  "metadata": {
    "og:site_name": "Hazel Docs",
    "og:image": "https://fromhazel.ai/images/og-docs.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Sign in",
        "href": "https://app.fromhazel.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get a demo",
      "href": "https://calendly.com/clint-dunn/clint-hazel-intro"
    }
  },
  "anchors": [
    {
      "anchor": "Book a call",
      "href": "https://calendly.com/clint-dunn/clint-hazel-intro",
      "icon": "calendar"
    },
    {
      "anchor": "What's new",
      "href": "/resources/whats-new",
      "icon": "sparkles"
    }
  ],
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/fromhazel"
    },
    "links": [
      {
        "header": "Get started",
        "items": [
          { "label": "Book an intro call", "href": "https://calendly.com/clint-dunn/clint-hazel-intro" }
        ]
      }
    ]
  },
  "search": {
    "prompt": "Search Hazel docs..."
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
              "getting-started/welcome",
              "getting-started/quickstart",
              "getting-started/key-concepts",
              "getting-started/prompting-tips"
            ]
          },
          {
            "group": "Features",
            "icon": "sparkles",
            "pages": [
              "features/chat",
              "features/ask-vs-deep-thinking",
              "features/charts-and-tables",
              "features/citations",
              "features/memory",
              "features/scheduled-reports",
              "features/weekly-reviews",
              "features/alerts",
              "features/team-management"
            ]
          },
          {
            "group": "Resources",
            "icon": "life-buoy",
            "pages": [
              "resources/faq",
              "resources/whats-new",
              "resources/contact-support",
              "resources/security"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "icon": "plug",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "integrations/overview",
              "integrations/connecting-a-source",
              "integrations/all-integrations"
            ]
          },
          {
            "group": "Marketing",
            "pages": [
              "integrations/meta-ads",
              "integrations/google-ads",
              "integrations/google-analytics",
              "integrations/google-search-console",
              "integrations/tiktok-ads",
              "integrations/pinterest-ads",
              "integrations/snapchat-ads",
              "integrations/reddit-ads",
              "integrations/klaviyo",
              "integrations/attentive",
              "integrations/fairing",
              "integrations/tracksuit"
            ]
          },
          {
            "group": "Sales & commerce",
            "pages": [
              "integrations/shopify",
              "integrations/amazon",
              "integrations/amazon-ads"
            ]
          },
          {
            "group": "Subscriptions",
            "pages": [
              "integrations/recharge",
              "integrations/skio"
            ]
          },
          {
            "group": "Support",
            "pages": [
              "integrations/gorgias",
              "integrations/zendesk"
            ]
          },
          {
            "group": "Returns",
            "pages": [
              "integrations/loop-returns"
            ]
          },
          {
            "group": "Reviews & surveys",
            "pages": [
              "integrations/okendo",
              "integrations/yotpo"
            ]
          }
        ]
      },
      {
        "tab": "Recipes & prompts",
        "icon": "lightbulb",
        "groups": [
          {
            "group": "Prompt library",
            "pages": [
              "recipes/overview",
              "recipes/marketing-analysis",
              "recipes/customer-insights",
              "recipes/product-performance",
              "recipes/ad-spend-optimization",
              "recipes/retention-and-ltv",
              "recipes/support-operations",
              "recipes/weekly-reporting",
              "recipes/fraud-detection",
              "recipes/subscription-analysis",
              "recipes/pricing-strategy"
            ]
          }
        ]
      }
    ]
  }
}
